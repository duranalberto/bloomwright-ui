{
  "name": "bloomwright-ui",
  "version": "0.1.0",
  "description": "A DaisyUI-based Astro UI kit and render core: presentation components, pure domain logic, the ECharts SSR engine and the Mermaid render pipeline (with a caller-owned render port), client web components, styles, and shared types. Consumed by apps and by bloomwright-mdx.",
  "type": "module",
  "license": "MIT",
  "author": "Alberto Duran",
  "keywords": ["astro", "astro-component", "daisyui", "tailwindcss", "ui-kit", "components", "echarts", "mermaid"],
  "engines": {
    "node": ">=22.13.0"
  },
  "sideEffects": ["*.css", "./src/runtime/*.ts"],
  "files": ["src", "README.md", "LICENSE"],
  "exports": {
    ".": "./src/index.ts",
    "./echarts": "./src/echarts/index.ts",
    "./mermaid": "./src/mermaid/index.ts",
    "./mermaid-renderer": "./src/mermaid/renderer-integration.ts",
    "./cache": "./src/shared/cache.ts",
    "./components/*": "./src/components/*",
    "./logic/*": "./src/logic/*.ts",
    "./runtime/*": "./src/runtime/*.ts",
    "./styles.css": "./src/styles/index.css",
    "./daisyui-preset.css": "./src/styles/daisyui-preset.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "guard:leaf": "node scripts/check-leaf-invariant.mjs"
  },
  "peerDependencies": {
    "astro": "^7.0.0",
    "daisyui": "^5.5.0",
    "echarts": "^6.1.0",
    "tailwindcss": "^4.3.0"
  },
  "peerDependenciesMeta": {
    "daisyui": { "optional": false },
    "tailwindcss": { "optional": false },
    "echarts": { "optional": false }
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "hast-util-from-html": "^2.0.3",
    "hast-util-select": "^6.0.4",
    "hast-util-to-html": "^9.0.5",
    "postcss": "^8.5.15",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/hast": "^3.0.4",
    "@types/node": "^26.0.0",
    "astro": "^7.0.3",
    "daisyui": "^5.5.23",
    "echarts": "6.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
