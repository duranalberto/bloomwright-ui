---
import type { Icon } from "../../types/icon.ts";
import { resolveHeadingTag } from "../../logic/heading-anchor.ts";
import SVGIcon from "../primitive/SVGIcon.astro";

/**
 * HeadingAnchor — a prose heading with a copy-link affordance.
 *
 * Dual-use: drop it into any `.astro` page directly (`<HeadingAnchor as="h2"
 * id="intro">Intro</HeadingAnchor>`), or map it to `h2`/`h3` in an MDX
 * `components` map. The rendered tag comes from `resolveHeadingTag(as)`, the
 * same helper bloomwright-mdx's `createHeadingAnchorPlugin()` targets.
 *
 * FR-C4: the anchor + "copied" glyphs are supplied as props with built-in
 * inline defaults, so bloomwright-ui ships no icon *data* dependency
 * (`@data/icons` stays in the consuming app). Pass `linkIcon` / `checkIcon`
 * to override the defaults with your own design-system glyphs.
 */

export interface Props {
  id?: string;
  class?: string;
  as?: string;
  linkIcon?: Icon;
  checkIcon?: Icon;
  [key: string]: unknown;
}

const DEFAULT_LINK_ICON: Icon = {
  text: "Link",
  viewBox: "0 0 24 24",
  content: `
    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
  `,
  fill: "none",
  stroke: "currentColor",
  strokeWidth: 2.5,
  strokeLinecap: "round",
  strokeLinejoin: "round",
};

const DEFAULT_CHECK_ICON: Icon = {
  text: "Copied",
  viewBox: "0 0 24 24",
  content: `<path d="M20 6 9 17l-5-5" />`,
  fill: "none",
  stroke: "currentColor",
  strokeWidth: 2.5,
  strokeLinecap: "round",
  strokeLinejoin: "round",
};

const {
  id,
  class: className,
  as,
  linkIcon = DEFAULT_LINK_ICON,
  checkIcon = DEFAULT_CHECK_ICON,
  ...rest
} = Astro.props;
const Tag = resolveHeadingTag(as);
---

<anchor-heading>
  <Tag
    id={id}
    class:list={[
      "group relative flex items-center gap-3 scroll-mt-24",
      "font-display font-bold text-base-content",
      className,
    ]}
    {...rest}
  >
    <slot />

    {
      id && (
        <span class="relative inline-flex items-center shrink-0">
          <button
            type="button"
            class:list={[
              "anchor-trigger",
              "inline-flex items-center justify-center shrink-0",
              "w-9 h-9 rounded-md cursor-pointer",
              "text-base-content/40 hover:text-primary",
              "transition-colors duration-200",
              "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50",
              "bg-transparent border-0",
            ]}
            aria-label="Copy link to section"
            data-anchor-trigger
            data-state="idle"
          >
            <span class="anchor-icon anchor-icon-link" aria-hidden="true">
              <SVGIcon icon={linkIcon} width={18} height={18} />
            </span>

            <span
              class="anchor-icon anchor-icon-check text-success"
              aria-hidden="true"
            >
              <SVGIcon icon={checkIcon} width={18} height={18} />
            </span>
          </button>

          <span
            class="sr-only"
            role="status"
            aria-live="polite"
            data-anchor-feedback
          />
        </span>
      )
    }
  </Tag>
</anchor-heading>

<script>
  class AnchorHeading extends HTMLElement {
    private resetTimer: ReturnType<typeof setTimeout> | null = null;

    connectedCallback() {
      const trigger = this.querySelector<HTMLButtonElement>(
        "[data-anchor-trigger]",
      );
      if (trigger) {
        trigger.addEventListener("click", (e) => this.handleCopy(e));
      }
    }

    private handleCopy = async (e: MouseEvent): Promise<void> => {
      const trigger = e.currentTarget as HTMLButtonElement;
      const heading = this.querySelector("[id]");
      const feedback = this.querySelector<HTMLElement>(
        "[data-anchor-feedback]",
      );

      if (!heading?.id) return;

      const url = new URL(window.location.href);
      url.hash = heading.id;

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(url.toString());
        } else {
          window.location.hash = heading.id;
        }
        this.showCopied(trigger, feedback);
      } catch (err) {
        console.error("Failed to copy anchor:", err);
      }
    };

    private showCopied(
      trigger: HTMLButtonElement,
      feedback: HTMLElement | null,
    ): void {
      if (this.resetTimer) clearTimeout(this.resetTimer);

      trigger.dataset.state = "copied";
      trigger.setAttribute("aria-label", "Link copied!");
      if (feedback) feedback.textContent = "Copied!";

      this.resetTimer = setTimeout(() => {
        trigger.dataset.state = "idle";
        trigger.setAttribute("aria-label", "Copy link to section");
        if (feedback) feedback.textContent = "";
        this.resetTimer = null;
      }, 2000);
    }
  }

  if (!customElements.get("anchor-heading")) {
    customElements.define("anchor-heading", AnchorHeading);
  }
</script>
